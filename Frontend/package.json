{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build:view": "rm -rf view && cd ../frontend && npm run build && cp -r dist ../backend/view",
    "push": "git add . && git commit -m \"Update frontend build\" && git push",
    "deploy": "npm run build:view && npm run push"
  },
  "dependencies": {
    "@ferrucc-io/emoji-picker": "^0.0.45",
    "@react-oauth/google": "^0.12.2",
    "@tailwindcss/vite": "^4.1.13",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-nice-avatar": "^1.5.0",
    "react-router-dom": "^7.8.2",
    "react-toastify": "^11.0.5",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.1.2"
  }
}
